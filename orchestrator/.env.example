# Copy this file to .env and adjust to your configuration

# --- Engine Selection ---
TTS_ENGINE=gpt_sovits

# LLM Backend: "ollama" hoặc "vllm"
# Nếu dùng vllm, LLM_MODEL phải là đường dẫn HuggingFace (ví dụ: Qwen/Qwen2.5-14B-Instruct-AWQ)
LLM_BACKEND=ollama
LLM_MODEL=qwen2.5:14b

# --- Hardware Profile ---
VRAM_PROFILE=16gb

# --- Features ---
ENABLE_LIPSYNC=false
ENABLE_PROPAINTER=false
ENABLE_CPU_OFFLOAD=false
ENABLE_KVCACHED=false

# --- Logging ---
LOG_LEVEL=INFO
