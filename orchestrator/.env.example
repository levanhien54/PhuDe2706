# Copy this file to .env (project root) and adjust to your configuration.
# setup_native.ps1 / setup_offline.ps1 copy this to ./.env on a fresh machine.

# --- Engine Selection ---
# TTS_ENGINE: "omnivoice" (default, voice-cloning) hoặc "gpt_sovits"
TTS_ENGINE=omnivoice

# LLM Backend: "ollama" hoặc "vllm"
# Nếu dùng vllm, LLM_MODEL phải là đường dẫn HuggingFace (vd: Qwen/Qwen2.5-14B-Instruct-AWQ)
LLM_BACKEND=ollama
LLM_MODEL=qwen2.5:14b
# Lượng tử hóa cho backend vLLM: "awq" hoặc "fp8" (rỗng = full/Ollama Q4). AWQ/FP8 giảm VRAM
# LLM ~9GB -> ~4.5GB; khi bật, LLM_MODEL phải trỏ tới model đã lượng tử (vd ...-AWQ). Chỉ có tác
# dụng khi LLM_BACKEND=vllm.
LLM_QUANTIZATION=

# --- Hardware Profile ---
# 24gb cho RTX 3090/4090 (23-24GB). Hạ xuống 16gb nếu GPU nhỏ hơn.
VRAM_PROFILE=24gb

# --- Features ---
ENABLE_LIPSYNC=false
# Engine lip-sync: "latentsync" (chất lượng, mặc định) hoặc "musetalk" (nhanh hơn, chưa test kỹ).
LIPSYNC_ENGINE=latentsync
ENABLE_PROPAINTER=false
# ProPainter HD/OOM: FP16 (0/1) nửa VRAM; RESIZE_RATIO<1.0 downscale trước inpaint;
# SUBVIDEO_LENGTH nhỏ hơn = ít frame/pass = ít VRAM (giảm nếu OOM ở 1080p+).
PROPAINTER_FP16=1
PROPAINTER_RESIZE_RATIO=1.0
PROPAINTER_SUBVIDEO_LENGTH=80
# NEO CPU offload (chỉ vLLM): đẩy bớt trọng số LLM sang RAM để model lớn vừa GPU 16GB (chậm hơn).
ENABLE_CPU_OFFLOAD=false
CPU_OFFLOAD_GB=4
# Reserved: kvcached (chia sẻ KV-cache/GPU) — CHƯA tích hợp, bật vào chỉ log cảnh báo rồi no-op.
ENABLE_KVCACHED=false
# Khử nhiễu nền nhẹ khi ghép (đặt 0 nếu nội dung nhiều nhạc bị mờ)
BG_DENOISE=1

# --- Model paths (offline) ---
# large-v3-turbo: ~50% nhanh hơn, VRAM ~3GB, WER gần bằng large-v3. Đổi lại large-v3 nếu cần chất lượng tối đa.
WHISPER_MODEL=large-v3-turbo
WHISPER_MODEL_DIR=./models/whisper
# Tách nhạc/giọng: "demucs" (mặc định) hoặc "bs_roformer" (SOTA, cần cài audio-separator, CHƯA TEST).
SEPARATION_ENGINE=demucs
SEPARATION_MODEL=model_bs_roformer_ep_317_sdr_12.9755.ckpt
# Model gốc 646 ngôn ngữ (nghe tốt hơn bản fine-tune trong test A/B). Đổi sang ./models/omnivoice-vi nếu muốn thử fine-tune VN.
OMNIVOICE_MODEL_DIR=./models/omnivoice

# --- Speed / parallelism tuning ---
WHISPER_PRELOAD=1
WHISPER_BATCH_SIZE=32
# OmniVoice TTS: số replica + số request song song (giữ 2 giá trị BẰNG NHAU). Mỗi replica ~3GB VRAM.
OMNIVOICE_REPLICAS=2
TTS_CONCURRENCY=2
# OmniVoice num_step: cao hơn = chất lượng tốt hơn (model gốc). 64 = chất lượng cao (vẫn nhanh).
OMNIVOICE_NUM_STEP=64
OMNIVOICE_GUIDANCE=2.0
# Chế độ giọng mặc định: multi (đa nhân vật, tự nhận diện) hoặc single (một giọng đọc). Đổi được từng video trên giao diện.
VOICE_MODE=multi
# Dịch song song nhiều chunk; OLLAMA_NUM_PARALLEL cho Ollama xử lý chồng request (thêm VRAM KV-cache).
LLM_CONCURRENCY=4
OLLAMA_NUM_PARALLEL=2

# --- Logging ---
LOG_LEVEL=INFO
